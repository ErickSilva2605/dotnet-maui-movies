<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiMovies.UI.Pages.Main.MainContainerPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:nav="clr-namespace:MauiMovies.UI.Controls.Navigation"
    Shell.BackgroundColor="{AppThemeBinding Dark={StaticResource BackgroundDark},
                                            Light={StaticResource BackgroundLight}}"
    Shell.TabBarIsVisible="False"
    >
    <Shell.TitleView>
        <nav:TopBar SearchCommand="{Binding SearchCommand}" UserCommand="{Binding NavigateToUserCommand}" />
    </Shell.TitleView>
    <Grid RowDefinitions="*,Auto">
        <Grid x:Name="tabContainer" Grid.Row="0" />
        <nav:CustomTabBarView x:Name="bottomBar" Grid.Row="1" />
    </Grid>
</ContentPage>

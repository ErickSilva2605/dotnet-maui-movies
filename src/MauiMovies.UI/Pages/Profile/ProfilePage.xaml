<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiMovies.UI.Pages.Profile.ProfilePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:constants="clr-namespace:MauiMovies.UI.Constants"
    xmlns:strings="clr-namespace:MauiMovies.UI.Resources.Strings"
    xmlns:vm="clr-namespace:MauiMovies.Core.ViewModels;assembly=MauiMovies.Core"
    x:DataType="vm:ProfileViewModel"
    Shell.NavBarIsVisible="False"
    >
    <ScrollView Padding="0,12,0,24">
        <VerticalStackLayout Spacing="16">

            <!--  Top bar: back + logout  -->
            <Grid Margin="12,0" ColumnDefinitions="Auto,*,Auto">
                <Button
                    Grid.Column="0"
                    AutomationId="Profile_BackButton"
                    Command="{Binding GoBackCommand}"
                    HorizontalOptions="Start"
                    Style="{StaticResource IconButton}"
                    >
                    <Button.ImageSource>
                        <FontImageSource
                            FontFamily="Lucide"
                            Glyph="{x:Static constants:LucideIcons.ArrowLeft}"
                            Size="24"
                            Color="{AppThemeBinding Dark={StaticResource TopBarIconColorDark},
                                                    Light={StaticResource TopBarIconColorLight}}"
                            />
                    </Button.ImageSource>
                </Button>

                <Button
                    Grid.Column="2"
                    AutomationId="Profile_LogoutButton"
                    Command="{Binding SignOutCommand}"
                    HorizontalOptions="End"
                    Style="{StaticResource IconButtonTransparent}"
                    >
                    <Button.ImageSource>
                        <FontImageSource
                            FontFamily="Lucide"
                            Glyph="{x:Static constants:LucideIcons.LogOut}"
                            Size="24"
                            Color="#FF6B6B"
                            />
                    </Button.ImageSource>
                </Button>
            </Grid>

            <!--  Avatar + Hello  -->
            <HorizontalStackLayout Margin="24,12,24,12" Spacing="16" VerticalOptions="Center">
                <Border
                    BackgroundColor="{StaticResource Secondary}"
                    HeightRequest="80"
                    StrokeShape="RoundRectangle 40"
                    StrokeThickness="0"
                    WidthRequest="80"
                    >
                    <Image
                        HeightRequest="48"
                        HorizontalOptions="Center"
                        VerticalOptions="Center"
                        WidthRequest="48"
                        >
                        <Image.Source>
                            <FontImageSource
                                FontFamily="Lucide"
                                Glyph="{x:Static constants:LucideIcons.User}"
                                Size="48"
                                Color="White"
                                />
                        </Image.Source>
                    </Image>
                </Border>
                <VerticalStackLayout VerticalOptions="Center">
                    <Label
                        Style="{StaticResource LabelBody}"
                        Text="{x:Static strings:AppResources.Profile_Hello}"
                        />
                    <Label
                        AutomationId="Profile_UsernameLabel"
                        FontSize="22"
                        LineBreakMode="TailTruncation"
                        Style="{StaticResource LabelPageTitle}"
                        Text="{Binding Username, StringFormat='({0})', FallbackValue=Guest}"
                        />
                </VerticalStackLayout>
            </HorizontalStackLayout>

            <!--  Menu rows  -->
            <VerticalStackLayout Padding="12,0" Spacing="12">

                <Border Padding="20,16" Style="{StaticResource SurfaceCard}">
                    <Grid ColumnDefinitions="32,*,24" ColumnSpacing="16">
                        <Image Grid.Column="0" HeightRequest="24" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.List}"
                                    Size="24"
                                    Color="{StaticResource Secondary}"
                                    />
                            </Image.Source>
                        </Image>
                        <Label
                            Grid.Column="1"
                            FontSize="18"
                            Style="{StaticResource LabelSectionTitle}"
                            Text="{x:Static strings:AppResources.Profile_Lists}"
                            VerticalOptions="Center"
                            />
                        <Image Grid.Column="2" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.ChevronRight}"
                                    Size="20"
                                    Color="{AppThemeBinding Dark={StaticResource OnBackgroundDark},
                                                            Light={StaticResource OnBackgroundLight}}"
                                    />
                            </Image.Source>
                        </Image>
                    </Grid>
                </Border>

                <Border Padding="20,16" Style="{StaticResource SurfaceCard}">
                    <Grid ColumnDefinitions="32,*,24" ColumnSpacing="16">
                        <Image Grid.Column="0" HeightRequest="24" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.Heart}"
                                    Size="24"
                                    Color="{StaticResource Secondary}"
                                    />
                            </Image.Source>
                        </Image>
                        <Label
                            Grid.Column="1"
                            FontSize="18"
                            Style="{StaticResource LabelSectionTitle}"
                            Text="{x:Static strings:AppResources.Profile_Favorites}"
                            VerticalOptions="Center"
                            />
                        <Image Grid.Column="2" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.ChevronRight}"
                                    Size="20"
                                    Color="{AppThemeBinding Dark={StaticResource OnBackgroundDark},
                                                            Light={StaticResource OnBackgroundLight}}"
                                    />
                            </Image.Source>
                        </Image>
                    </Grid>
                </Border>

                <Border Padding="20,16" Style="{StaticResource SurfaceCard}">
                    <Grid ColumnDefinitions="32,*,24" ColumnSpacing="16">
                        <Image Grid.Column="0" HeightRequest="24" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.Bookmark}"
                                    Size="24"
                                    Color="{StaticResource Secondary}"
                                    />
                            </Image.Source>
                        </Image>
                        <Label
                            Grid.Column="1"
                            FontSize="18"
                            Style="{StaticResource LabelSectionTitle}"
                            Text="{x:Static strings:AppResources.Profile_Watchlist}"
                            VerticalOptions="Center"
                            />
                        <Image Grid.Column="2" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.ChevronRight}"
                                    Size="20"
                                    Color="{AppThemeBinding Dark={StaticResource OnBackgroundDark},
                                                            Light={StaticResource OnBackgroundLight}}"
                                    />
                            </Image.Source>
                        </Image>
                    </Grid>
                </Border>

                <Border Padding="20,16" Style="{StaticResource SurfaceCard}">
                    <Grid ColumnDefinitions="32,*,24" ColumnSpacing="16">
                        <Image Grid.Column="0" HeightRequest="24" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.Star}"
                                    Size="24"
                                    Color="{StaticResource Secondary}"
                                    />
                            </Image.Source>
                        </Image>
                        <Label
                            Grid.Column="1"
                            FontSize="18"
                            Style="{StaticResource LabelSectionTitle}"
                            Text="{x:Static strings:AppResources.Profile_Ratings}"
                            VerticalOptions="Center"
                            />
                        <Image Grid.Column="2" HeightRequest="20" VerticalOptions="Center">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.ChevronRight}"
                                    Size="20"
                                    Color="{AppThemeBinding Dark={StaticResource OnBackgroundDark},
                                                            Light={StaticResource OnBackgroundLight}}"
                                    />
                            </Image.Source>
                        </Image>
                    </Grid>
                </Border>

            </VerticalStackLayout>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiMovies.UI.Pages.PreLogin.PreLoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:constants="clr-namespace:MauiMovies.UI.Constants"
    xmlns:strings="clr-namespace:MauiMovies.UI.Resources.Strings"
    xmlns:vm="clr-namespace:MauiMovies.Core.ViewModels;assembly=MauiMovies.Core"
    x:DataType="vm:PreLoginViewModel"
    Shell.NavBarIsVisible="False"
    >
    <Grid Padding="0,12,0,24" RowDefinitions="Auto,*,Auto" RowSpacing="0">

        <!--  Back arrow  -->
        <Button
            Grid.Row="0"
            Margin="12,0"
            AutomationId="PreLogin_BackButton"
            Command="{Binding GoBackCommand}"
            HorizontalOptions="Start"
            Style="{StaticResource IconButton}"
            >
            <Button.ImageSource>
                <FontImageSource
                    FontFamily="Lucide"
                    Glyph="{x:Static constants:LucideIcons.ArrowLeft}"
                    Size="24"
                    Color="{AppThemeBinding Dark={StaticResource TopBarIconColorDark},
                                            Light={StaticResource TopBarIconColorLight}}"
                    />
            </Button.ImageSource>
        </Button>

        <!--  Conteúdo  -->
        <ScrollView Grid.Row="1" Padding="24,12,24,24">
            <VerticalStackLayout Spacing="16">

                <!--  Title  -->
                <Label
                    Margin="0,16,0,16"
                    HorizontalTextAlignment="Center"
                    Style="{StaticResource LabelPageTitle}"
                    Text="{x:Static strings:AppResources.PreLogin_Title}"
                    />

                <!--  Benefit cards  -->
                <Border Padding="16" Style="{StaticResource SurfaceCard}">
                    <HorizontalStackLayout Spacing="16" VerticalOptions="Center">
                        <Image HeightRequest="28" VerticalOptions="Center" WidthRequest="28">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.Star}"
                                    Size="28"
                                    Color="{StaticResource Secondary}"
                                    />
                            </Image.Source>
                        </Image>
                        <Label
                            HorizontalOptions="FillAndExpand"
                            Style="{StaticResource LabelBody}"
                            Text="{x:Static strings:AppResources.PreLogin_Benefit_Rate}"
                            VerticalOptions="Center"
                            />
                    </HorizontalStackLayout>
                </Border>

                <Border Padding="16" Style="{StaticResource SurfaceCard}">
                    <HorizontalStackLayout Spacing="16" VerticalOptions="Center">
                        <Image HeightRequest="28" VerticalOptions="Center" WidthRequest="28">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.Heart}"
                                    Size="28"
                                    Color="{StaticResource Secondary}"
                                    />
                            </Image.Source>
                        </Image>
                        <Label
                            HorizontalOptions="FillAndExpand"
                            Style="{StaticResource LabelBody}"
                            Text="{x:Static strings:AppResources.PreLogin_Benefit_Lists}"
                            VerticalOptions="Center"
                            />
                    </HorizontalStackLayout>
                </Border>

                <Border Padding="16" Style="{StaticResource SurfaceCard}">
                    <HorizontalStackLayout Spacing="16" VerticalOptions="Center">
                        <Image HeightRequest="28" VerticalOptions="Center" WidthRequest="28">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.List}"
                                    Size="28"
                                    Color="{StaticResource Secondary}"
                                    />
                            </Image.Source>
                        </Image>
                        <Label
                            HorizontalOptions="FillAndExpand"
                            Style="{StaticResource LabelBody}"
                            Text="{x:Static strings:AppResources.PreLogin_Benefit_Personal}"
                            VerticalOptions="Center"
                            />
                    </HorizontalStackLayout>
                </Border>

                <Border Padding="16" Style="{StaticResource SurfaceCard}">
                    <HorizontalStackLayout Spacing="16" VerticalOptions="Center">
                        <Image HeightRequest="28" VerticalOptions="Center" WidthRequest="28">
                            <Image.Source>
                                <FontImageSource
                                    FontFamily="Lucide"
                                    Glyph="{x:Static constants:LucideIcons.Flame}"
                                    Size="28"
                                    Color="{StaticResource Secondary}"
                                    />
                            </Image.Source>
                        </Image>
                        <Label
                            HorizontalOptions="FillAndExpand"
                            Style="{StaticResource LabelBody}"
                            Text="{x:Static strings:AppResources.PreLogin_Benefit_Recommendations}"
                            VerticalOptions="Center"
                            />
                    </HorizontalStackLayout>
                </Border>

            </VerticalStackLayout>
        </ScrollView>

        <!--  Login + footer  -->
        <VerticalStackLayout Grid.Row="2" Padding="24,8" Spacing="12">
            <Button
                AutomationId="PreLogin_LoginButton"
                Command="{Binding NavigateToLoginCommand}"
                Style="{StaticResource ButtonOutline}"
                Text="{x:Static strings:AppResources.PreLogin_Login_Button}"
                />

            <Label
                HorizontalTextAlignment="Center"
                Style="{StaticResource LabelCaption}"
                Text="{x:Static strings:AppResources.PreLogin_Footer}"
                />
        </VerticalStackLayout>

    </Grid>
</ContentPage>
